{
  "name": "online-polling-system",
  "version": "1.0.0",
  "description": "Online Polling System - Lets users create and share interactive polls with support for multiple question types, anonymous voting, and live result charts. CA2 Project for INT222",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install"
  },
  "keywords": ["polling", "nodejs", "express", "socket.io"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "body-parser": "^1.20.2",
    "express-validator": "^7.0.1",
    "cookie-parser": "^1.4.6",
    "cookie-session": "^2.0.0",
    "express-session": "^1.17.3",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}

